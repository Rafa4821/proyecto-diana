rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper functions ───────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/adminUsers/$(request.auth.uid));
    }

    function isAllowedImageType() {
      return request.resource.contentType.matches('image/jpeg')
          || request.resource.contentType.matches('image/png')
          || request.resource.contentType.matches('image/webp');
    }

    function isAllowedProofType() {
      return request.resource.contentType.matches('image/jpeg')
          || request.resource.contentType.matches('image/png')
          || request.resource.contentType.matches('image/webp')
          || request.resource.contentType.matches('application/pdf');
    }

    function isUnder5MB() {
      return request.resource.size <= 5 * 1024 * 1024;
    }

    // ─── uploads/ (media library) ───────────────────────────
    // Public read (images served on the site)
    // Only admin can upload and delete
    match /uploads/{allPaths=**} {
      allow read: if true;
      allow create: if isAdmin()
                    && isAllowedImageType()
                    && isUnder5MB();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── transfer-proofs/ (payment proof uploads) ───────────
    // Anyone can upload with validation (no auth required for checkout flow)
    // Only admin can read and delete
    match /transfer-proofs/{fileName} {
      allow read: if isAdmin();
      allow create: if isAllowedProofType()
                    && isUnder5MB();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Deny everything else ───────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
